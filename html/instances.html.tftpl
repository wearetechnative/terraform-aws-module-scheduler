<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#112f41">
  <link rel="icon" href="favicon.svg" type="image/svg+xml">
  <title>Instances · Instance Scheduler</title>
  <script src="auth.js"></script>
  <style>
    :root { --ink:#112f41; --muted:#607582; --line:#dce7eb; --paper:#f3f7f8; --accent:#72c8d3; --dark:#112f41; --danger:#a93838; }
    * { box-sizing:border-box; }
    body { margin:0; color:var(--ink); background:var(--paper); font:15px/1.5 Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; }
    a { color:inherit; text-decoration:none; }
    button,input,select { font:inherit; }
    .shell { min-height:100vh; display:grid; grid-template-columns:248px 1fr; }
    .sidebar { position:sticky; top:0; height:100vh; padding:28px 20px; background:var(--dark); color:#fff; display:flex; flex-direction:column; }
    .brand { display:block; margin-bottom:28px; padding:10px 12px; border-radius:12px; background:#fff; }
    .brand-logo { display:block; width:100%; height:auto; }
    .nav-label { margin:0 10px 9px; color:#89938e; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.11em; }
    .nav { display:grid; gap:6px; }
    .nav a { display:flex; gap:12px; align-items:center; padding:11px 12px; border-radius:10px; color:#aeb8b2; font-weight:600; }
    .nav a:hover,.nav a.active { color:#fff; background:#1b4359; }
    .nav a.active::before { content:""; width:4px; height:18px; border-radius:9px; background:var(--accent); margin-left:-12px; }
    .nav svg { width:18px; height:18px; }
    .sidebar-foot { margin-top:auto; padding:16px; border:1px solid #35413b; border-radius:14px; color:#9da8a2; font-size:12px; }
    .sidebar-foot strong { display:block; color:#fff; font-size:13px; margin-bottom:4px; }
    main { padding:36px 44px 60px; min-width:0; }
    .topbar { display:flex; justify-content:space-between; align-items:flex-end; gap:20px; margin-bottom:28px; }
    .eyebrow { margin:0 0 5px; color:var(--muted); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.12em; }
    h1 { margin:0; font-size:clamp(30px,3vw,42px); line-height:1.08; letter-spacing:-.045em; }
    .subtitle { margin:8px 0 0; color:var(--muted); }
    .btn { min-height:40px; padding:0 14px; display:inline-flex; align-items:center; justify-content:center; border:0; border-radius:9px; background:var(--dark); color:#fff; cursor:pointer; font-weight:700; }
    .btn:disabled { cursor:not-allowed; opacity:.5; }
    .btn.ghost { color:var(--muted); background:#eef1ec; }
    .summary { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:20px; }
    .summary-card { padding:18px 20px; background:#fff; border:1px solid var(--line); border-radius:14px; }
    .summary-card span { color:var(--muted); font-size:12px; font-weight:650; }
    .summary-card strong { display:block; margin-top:4px; font-size:23px; letter-spacing:-.03em; }
    .panel { background:#fff; border:1px solid var(--line); border-radius:18px; overflow:hidden; }
    .toolbar { display:flex; justify-content:space-between; align-items:center; gap:16px; padding:17px 20px; border-bottom:1px solid var(--line); }
    .search { width:min(360px,100%); position:relative; }
    .search svg { position:absolute; left:12px; top:12px; width:17px; color:var(--muted); }
    .search input { width:100%; height:41px; padding:0 12px 0 38px; border:1px solid var(--line); border-radius:9px; background:#fafbf9; outline:none; }
    .search input:focus,select:focus { border-color:#9aa68f; box-shadow:0 0 0 3px #edf2e4; outline:none; }
    .count { color:var(--muted); font-size:12px; font-weight:650; }
    table { width:100%; border-collapse:collapse; }
    th { padding:13px 18px; color:var(--muted); background:#fafbf9; border-bottom:1px solid var(--line); text-align:left; font-size:11px; text-transform:uppercase; letter-spacing:.08em; }
    td { padding:15px 18px; border-bottom:1px solid var(--line); vertical-align:middle; }
    tbody tr:last-child td { border-bottom:0; }
    tbody tr:hover { background:#fcfdfb; }
    .instance-name { font-weight:730; }
    .instance-id,.meta { color:var(--muted); font-size:11px; }
    .state { display:inline-flex; align-items:center; gap:7px; padding:5px 9px; border-radius:999px; font-size:11px; font-weight:750; text-transform:capitalize; }
    .state::before { content:""; width:6px; height:6px; border-radius:50%; background:currentColor; }
    .state.running { color:#25704b; background:#eaf7ef; }
    .state.stopped { color:#7a5555; background:#f7eeee; }
    .state.pending,.state.stopping { color:#806a28; background:#f8f3dd; }
    .assignment { display:flex; align-items:center; gap:8px; min-width:390px; }
    .assignment select { width:175px; height:39px; padding:0 10px; border:1px solid #d6dbd7; border-radius:9px; background:#fff; color:var(--ink); }
    .unmanaged { color:#8a6c2f; font-size:11px; font-weight:700; }
    .override { display:flex; align-items:center; gap:8px; min-width:210px; }
    .override-value { color:#806a28; font-size:11px; font-weight:700; }
    .state-message { padding:65px 20px; text-align:center; color:var(--muted); }
    .state-message strong { display:block; color:var(--ink); margin-bottom:5px; }
    .calendar-button { margin-left:auto; }
    #instanceCalendarDialog { width:min(1180px,calc(100% - 32px)); }
    .calendar-dialog-body { padding:0 24px 22px; overflow:auto; }
    .calendar-summary { display:flex; flex-wrap:wrap; gap:8px 18px; padding:15px 0; color:var(--muted); font-size:12px; }
    .calendar-summary strong { color:var(--ink); }
    .calendar-detail { min-width:940px; display:grid; grid-template-columns:72px repeat(7,minmax(115px,1fr)); border:1px solid var(--line); border-radius:12px; overflow:hidden; }
    .calendar-corner,.calendar-day-header { height:45px; display:grid; place-items:center; color:var(--muted); background:#fafbf9; border-bottom:1px solid var(--line); border-right:1px solid var(--line); font-size:11px; font-weight:750; text-transform:uppercase; letter-spacing:.06em; }
    .calendar-day-header:last-child { border-right:0; }
    .time-axis { position:relative; height:960px; border-right:1px solid var(--line); background:#fafbf9; }
    .time-label { position:absolute; right:9px; transform:translateY(-50%); color:#819099; font-size:10px; font-variant-numeric:tabular-nums; }
    .day-track { position:relative; height:960px; border-right:1px solid var(--line); background-color:#fff; background-image:linear-gradient(to bottom,transparent 39px,#e5ecef 39px,#e5ecef 40px); background-size:100% 40px; }
    .day-track:last-child { border-right:0; }
    .run-block { position:absolute; left:7px; right:7px; min-height:4px; padding:5px 7px; overflow:hidden; border-radius:7px; color:#155d3d; background:#bce8ce; border:1px solid #72c497; font-size:10px; font-weight:750; line-height:1.3; box-shadow:0 2px 6px rgba(37,112,75,.12); }
    .run-block strong { display:block; color:#174f38; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .stop-marker { position:absolute; left:5px; right:5px; height:2px; background:#c49427; }
    .stop-marker::before { content:""; position:absolute; left:0; top:-4px; width:10px; height:10px; border-radius:50%; background:#c49427; }
    .stop-marker span { position:absolute; left:14px; top:-9px; padding:2px 5px; border-radius:5px; color:#806a28; background:#fff4d7; font-size:9px; font-weight:750; white-space:nowrap; }
    .calendar-legend { display:flex; gap:18px; padding-top:12px; color:var(--muted); font-size:11px; }
    .calendar-legend span { display:inline-flex; align-items:center; gap:7px; }
    .legend-run { width:23px; height:10px; border:1px solid #72c497; border-radius:4px; background:#bce8ce; }
    .legend-stop { width:23px; height:2px; background:#c49427; }
    dialog { width:min(460px,calc(100% - 32px)); padding:0; border:0; border-radius:18px; color:var(--ink); box-shadow:0 24px 80px rgba(23,32,28,.25); }
    dialog::backdrop { background:rgba(16,24,20,.55); backdrop-filter:blur(3px); }
    .dialog-head { padding:22px 24px 17px; border-bottom:1px solid var(--line); }
    .dialog-head h2 { margin:0 0 5px; font-size:20px; letter-spacing:-.03em; }
    .dialog-head p { margin:0; color:var(--muted); font-size:13px; }
    .dialog-body { display:grid; gap:17px; padding:22px 24px; }
    .field label { display:block; margin-bottom:6px; font-size:12px; font-weight:750; }
    .field input,.field select { width:100%; height:43px; padding:0 12px; border:1px solid #d6dbd7; border-radius:9px; background:#fff; color:var(--ink); }
    .dialog-actions { display:flex; justify-content:space-between; gap:9px; padding:17px 24px; border-top:1px solid var(--line); background:#fafbf9; }
    .dialog-actions-right { display:flex; gap:9px; margin-left:auto; }
    .btn.danger { color:var(--danger); background:#fff0f0; }
    .toast { position:fixed; right:24px; bottom:24px; max-width:380px; padding:13px 16px; border-radius:11px; background:var(--dark); color:#fff; box-shadow:0 15px 40px rgba(0,0,0,.18); transform:translateY(20px); opacity:0; pointer-events:none; transition:.2s ease; font-size:13px; font-weight:650; }
    .toast.show { transform:translateY(0); opacity:1; }
    .toast.error { background:#8d3030; }
    @media (max-width:1100px) { .table-wrap{overflow-x:auto}table{min-width:950px} }
    @media (max-width:900px) { .shell{grid-template-columns:1fr}.sidebar{position:static;height:auto;padding:18px 20px}.brand{padding-bottom:15px}.nav-label,.sidebar-foot{display:none}.nav{display:flex;overflow-x:auto}.nav a{white-space:nowrap}main{padding:28px 20px 50px}.summary{grid-template-columns:1fr 1fr} }
    @media (max-width:600px) { .topbar{align-items:flex-start;flex-direction:column}.summary{grid-template-columns:1fr}.toolbar{align-items:flex-start;flex-direction:column}.search{width:100%} }
  </style>
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <a class="brand" href="index.html"><img class="brand-logo" src="technativelogo.svg" alt="TechNative"></a>
      <p class="nav-label">Workspace</p>
      <nav class="nav">
        <a href="index.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="2"/><rect x="14" y="3" width="7" height="7" rx="2"/><rect x="3" y="14" width="7" height="7" rx="2"/><rect x="14" y="14" width="7" height="7" rx="2"/></svg> Overview</a>
        <a href="schedules.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 10h18"/></svg> Schedules</a>
        <a href="periods.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg> Periods</a>
        <a class="active" href="instances.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="7" rx="2"/><rect x="3" y="13" width="18" height="7" rx="2"/><path d="M7 7.5h.01M7 16.5h.01"/></svg> Instances</a>
      </nav>
      <div class="sidebar-foot"><strong>EC2 tag</strong>Assignments are stored in the InstanceScheduler tag.</div>
    </aside>
    <main>
      <header class="topbar">
        <div><p class="eyebrow">EC2 inventory</p><h1>Instances</h1><p class="subtitle">See instance state and manage scheduler assignments.</p></div>
        <button class="btn ghost" id="refreshButton">Refresh</button>
      </header>
      <section class="summary">
        <div class="summary-card"><span>Total instances</span><strong id="totalCount">—</strong></div>
        <div class="summary-card"><span>Managed</span><strong id="managedCount">—</strong></div>
        <div class="summary-card"><span>Unmanaged</span><strong id="unmanagedCount">—</strong></div>
      </section>
      <section class="panel">
        <div class="toolbar">
          <div class="search"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg><input id="search" type="search" placeholder="Search name, ID, schedule…" aria-label="Search instances"></div>
          <div class="count" id="resultCount">Loading instances…</div>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Instance</th><th>State</th><th>Type</th><th>Location</th><th>Schedule assignment</th><th>Ignore scheduler</th></tr></thead>
            <tbody id="instanceRows"><tr><td colspan="6"><div class="state-message">Loading EC2 inventory…</div></td></tr></tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
  <dialog id="ignoreDialog">
    <form id="ignoreForm">
      <div class="dialog-head"><h2>Ignore scheduler</h2><p id="ignoreInstance">Keep this instance running until a specific local time.</p></div>
      <div class="dialog-body">
        <div class="field"><label for="ignoreTime">Ignore until</label><input id="ignoreTime" type="time" required></div>
        <div class="field"><label for="ignoreTimezone">Timezone</label><select id="ignoreTimezone" required><option>Europe/Amsterdam</option><option>Europe/London</option><option>UTC</option><option>America/New_York</option><option>America/Los_Angeles</option><option>Asia/Kolkata</option><option>Asia/Singapore</option><option>Australia/Sydney</option></select></div>
      </div>
      <div class="dialog-actions">
        <button class="btn danger" type="button" id="removeIgnore">Remove override</button>
        <div class="dialog-actions-right"><button class="btn ghost" type="button" id="cancelIgnore">Cancel</button><button class="btn" type="submit" id="saveIgnore">Save override</button></div>
      </div>
    </form>
  </dialog>
  <dialog id="instanceCalendarDialog">
    <div class="dialog-head"><h2 id="calendarTitle">Instance calendar</h2><p id="calendarSubtitle">Weekly scheduled operating windows.</p></div>
    <div class="calendar-dialog-body">
      <div class="calendar-summary" id="calendarSummary"></div>
      <div class="calendar-detail" id="calendarDetail"></div>
      <div class="calendar-legend"><span><i class="legend-run"></i>Scheduled running</span><span><i class="legend-stop"></i>Stop-only time</span></div>
    </div>
    <div class="dialog-actions"><div></div><button class="btn ghost" type="button" id="closeCalendar">Close</button></div>
  </dialog>
  <div class="toast" id="toast" role="status"></div>
  <script>
    const apiUrl = '${api_url}';
    const rows = document.getElementById('instanceRows');
    const calendarDialog = document.getElementById('instanceCalendarDialog');
    const calendarDetail = document.getElementById('calendarDetail');
    const weekdays = [
      {key:'mon', label:'Monday'},
      {key:'tue', label:'Tuesday'},
      {key:'wed', label:'Wednesday'},
      {key:'thu', label:'Thursday'},
      {key:'fri', label:'Friday'},
      {key:'sat', label:'Saturday'},
      {key:'sun', label:'Sunday'}
    ];
    let instances = [];
    let schedules = [];
    let schedulePeriods = {};
    let selectedIgnoreInstance = null;

    function request(path, options) {
      return fetch(apiUrl + path, options).then(function (response) {
        return response.text().then(function (text) {
          let data = {};
          try { data = text ? JSON.parse(text) : {}; } catch (error) { data = {message:text}; }
          if (!response.ok) throw new Error(data.message || 'Request failed');
          return data;
        });
      });
    }

    function toast(message, isError) {
      const element = document.getElementById('toast');
      element.textContent = message;
      element.className = 'toast show' + (isError ? ' error' : '');
      window.setTimeout(function () { element.className = 'toast'; }, 2800);
    }

    function updateSummary() {
      const managed = instances.filter(function (instance) { return instance.schedule; }).length;
      document.getElementById('totalCount').textContent = instances.length;
      document.getElementById('managedCount').textContent = managed;
      document.getElementById('unmanagedCount').textContent = instances.length - managed;
    }

    function attributeValue(attribute, fallback) {
      if (attribute === undefined || attribute === null) return fallback;
      if (typeof attribute !== 'object' || Array.isArray(attribute)) return attribute;
      if (Object.prototype.hasOwnProperty.call(attribute, 'S')) return attribute.S;
      if (Object.prototype.hasOwnProperty.call(attribute, 'SS')) return attribute.SS;
      return fallback;
    }

    function visibleInstances(filter) {
      const query = (filter || '').trim().toLowerCase();
      return instances.filter(function (instance) {
        return [instance.name, instance.instance_id, instance.schedule, instance.private_ip]
          .some(function (value) { return (value || '').toLowerCase().includes(query); });
      });
    }

    function render(filter) {
      const visible = visibleInstances(filter);
      document.getElementById('resultCount').textContent = visible.length + (visible.length === 1 ? ' instance' : ' instances');
      renderTable(visible);
    }

    function renderTable(visible) {
      rows.innerHTML = '';
      if (!visible.length) {
        rows.innerHTML = '<tr><td colspan="6"><div class="state-message"><strong>No instances found</strong>Try another search or check this AWS region.</div></td></tr>';
        return;
      }

      visible.forEach(function (instance) {
        const row = document.createElement('tr');
        const identity = document.createElement('td');
        const name = document.createElement('div'); name.className = 'instance-name'; name.textContent = instance.name || 'Unnamed instance';
        const id = document.createElement('div'); id.className = 'instance-id'; id.textContent = instance.instance_id;
        identity.appendChild(name); identity.appendChild(id);

        const stateCell = document.createElement('td');
        const state = document.createElement('span'); state.className = 'state ' + instance.state; state.textContent = instance.state; stateCell.appendChild(state);
        const type = document.createElement('td'); type.textContent = instance.instance_type;
        const location = document.createElement('td');
        location.innerHTML = '<div></div><div class="meta"></div>';
        location.children[0].textContent = instance.availability_zone;
        location.children[1].textContent = instance.private_ip || 'No private IP';

        const assignmentCell = document.createElement('td');
        const assignment = document.createElement('div'); assignment.className = 'assignment';
        const select = document.createElement('select');
        select.setAttribute('aria-label', 'Schedule for ' + instance.instance_id);
        const empty = document.createElement('option'); empty.value = ''; empty.textContent = 'No schedule'; select.appendChild(empty);
        schedules.forEach(function (schedule) {
          const option = document.createElement('option'); option.value = schedule; option.textContent = schedule; select.appendChild(option);
        });
        if (instance.schedule && !schedules.includes(instance.schedule)) {
          const unknown = document.createElement('option'); unknown.value = instance.schedule; unknown.textContent = instance.schedule + ' (missing)'; select.appendChild(unknown);
        }
        select.value = instance.schedule || '';
        const save = document.createElement('button'); save.className = 'btn'; save.textContent = instance.schedule ? 'Update' : 'Assign'; save.disabled = true;
        select.addEventListener('change', function () {
          save.disabled = select.value === (instance.schedule || '');
          save.textContent = select.value ? (instance.schedule ? 'Update' : 'Assign') : 'Remove';
        });
        save.addEventListener('click', function () { updateAssignment(instance, select, save); });
        assignment.appendChild(select); assignment.appendChild(save);
        assignmentCell.appendChild(assignment);

        const ignoreCell = document.createElement('td');
        const ignore = document.createElement('div'); ignore.className = 'override';
        const ignoreValue = document.createElement('span');
        ignoreValue.className = instance.ignore_scheduler ? 'override-value' : 'unmanaged';
        ignoreValue.textContent = instance.ignore_scheduler || 'No override';
        const ignoreButton = document.createElement('button');
        ignoreButton.className = 'btn ghost';
        ignoreButton.textContent = instance.ignore_scheduler ? 'Edit' : 'Set';
        ignoreButton.addEventListener('click', function () { openIgnoreDialog(instance); });
        ignore.appendChild(ignoreValue); ignore.appendChild(ignoreButton); ignoreCell.appendChild(ignore);

        const calendarButton = document.createElement('button');
        calendarButton.className = 'btn ghost calendar-button';
        calendarButton.textContent = 'Calendar';
        calendarButton.disabled = !instance.schedule;
        calendarButton.title = instance.schedule ? 'View weekly calendar' : 'Assign a schedule first';
        calendarButton.addEventListener('click', function () { openCalendar(instance); });
        assignment.appendChild(calendarButton);

        row.appendChild(identity); row.appendChild(stateCell); row.appendChild(type); row.appendChild(location); row.appendChild(assignmentCell); row.appendChild(ignoreCell);
        rows.appendChild(row);
      });
    }

    function openCalendar(instance) {
      if (!instance.schedule) return;
      document.getElementById('calendarTitle').textContent = instance.name || instance.instance_id;
      document.getElementById('calendarSubtitle').textContent = 'Weekly calendar for ' + instance.schedule;
      const summary = document.getElementById('calendarSummary');
      summary.innerHTML = '<span><strong>Instance:</strong> ' + escapeHtml(instance.instance_id) + '</span>' +
        '<span><strong>Schedule:</strong> ' + escapeHtml(instance.schedule) + '</span>' +
        '<span><strong>State:</strong> ' + escapeHtml(instance.state) + '</span>' +
        (instance.ignore_scheduler ? '<span><strong>Override:</strong> ' + escapeHtml(instance.ignore_scheduler) + '</span>' : '');
      renderInstanceCalendar(schedulePeriods[instance.schedule] || []);
      calendarDialog.showModal();
    }

    function renderInstanceCalendar(periods) {
      calendarDetail.innerHTML = '';
      const corner = document.createElement('div');
      corner.className = 'calendar-corner';
      corner.textContent = 'Time';
      calendarDetail.appendChild(corner);
      weekdays.forEach(function (day) {
        const header = document.createElement('div');
        header.className = 'calendar-day-header';
        header.textContent = day.label;
        calendarDetail.appendChild(header);
      });
      const timeAxis = document.createElement('div');
      timeAxis.className = 'time-axis';
      for (let hour = 0; hour < 24; hour += 1) {
        const label = document.createElement('span');
        label.className = 'time-label';
        label.style.top = (hour * 40) + 'px';
        label.textContent = String(hour).padStart(2, '0') + ':00';
        timeAxis.appendChild(label);
      }
      calendarDetail.appendChild(timeAxis);

      weekdays.forEach(function (day) {
        const track = document.createElement('div');
        track.className = 'day-track';
        periods.filter(function (period) {
          return period.days.includes(day.key);
        }).forEach(function (period) {
          const endMinutes = timeToMinutes(period.end);
          if (period.begin) {
            const beginMinutes = timeToMinutes(period.begin);
            const duration = Math.max(1, endMinutes - beginMinutes);
            const block = document.createElement('div');
            block.className = 'run-block';
            block.style.top = (beginMinutes / 1440 * 960) + 'px';
            block.style.height = Math.max(4, duration / 1440 * 960) + 'px';
            block.title = period.name + ': ' + period.begin + '–' + period.end + ' (' + period.timezone + ')';
            block.innerHTML = '<strong>' + escapeHtml(period.name) + '</strong>' +
              escapeHtml(period.begin + '–' + period.end);
            track.appendChild(block);
          } else {
            const marker = document.createElement('div');
            marker.className = 'stop-marker';
            marker.style.top = (endMinutes / 1440 * 960) + 'px';
            marker.title = period.name + ': stop at ' + period.end + ' (' + period.timezone + ')';
            const label = document.createElement('span');
            label.textContent = period.name + ' · ' + period.end;
            marker.appendChild(label);
            track.appendChild(marker);
          }
        });
        calendarDetail.appendChild(track);
      });
    }

    function timeToMinutes(value) {
      const parts = (value || '00:00').split(':');
      return (Number(parts[0]) * 60) + Number(parts[1]);
    }

    function escapeHtml(value) {
      const element = document.createElement('div');
      element.textContent = value;
      return element.innerHTML;
    }

    function loadSchedulePeriods(scheduleNames) {
      return Promise.all(scheduleNames.map(function (scheduleName) {
        return request('/db/list_periods', {
          method:'POST',
          headers:{'Content-Type':'text/plain;charset=UTF-8'},
          body:JSON.stringify({schedule_name:scheduleName})
        }).then(function (data) {
          schedulePeriods[scheduleName] = (data.period_list || []).map(function (period) {
            return {
              name:attributeValue(period.name, ''),
              days:attributeValue(period.days, []),
              begin:attributeValue(period.begintime, ''),
              end:attributeValue(period.endtime, ''),
              timezone:attributeValue(period.timezone, 'UTC')
            };
          });
        }).catch(function (error) {
          console.error('Calendar period loading failed for ' + scheduleName + ':', error);
          schedulePeriods[scheduleName] = [];
        });
      }));
    }

    function updateAssignment(instance, select, button) {
      const nextSchedule = select.value;
      const action = nextSchedule ? 'assign “' + nextSchedule + '” to' : 'remove the schedule from';
      if (!window.confirm('Do you want to ' + action + ' ' + (instance.name || instance.instance_id) + '?')) {
        select.value = instance.schedule || '';
        button.disabled = true;
        return;
      }
      button.disabled = true;
      button.textContent = 'Saving…';
      request('/instances/schedule', {
        method:'POST',
        headers:{'Content-Type':'text/plain;charset=UTF-8'},
        body:JSON.stringify({instance_id:instance.instance_id, schedule_name:nextSchedule})
      })
        .then(function () {
          instance.schedule = nextSchedule;
          toast(nextSchedule ? 'Schedule assigned' : 'Schedule removed');
          updateSummary();
          render(document.getElementById('search').value);
        })
        .catch(function (error) {
          console.error('Instance schedule update failed:', error);
          select.value = instance.schedule || '';
          button.disabled = false;
          button.textContent = 'Retry';
          toast(error.message || 'Could not update instance', true);
        });
    }

    function load() {
      document.getElementById('refreshButton').disabled = true;
      rows.innerHTML = '<tr><td colspan="6"><div class="state-message">Loading EC2 inventory…</div></td></tr>';
      Promise.all([request('/instances'), request('/db')])
        .then(function (results) {
          instances = results[0].instances || [];
          schedules = results[1].schedules_list || [];
          schedulePeriods = {};
          return loadSchedulePeriods(schedules);
        })
        .then(function () {
          updateSummary();
          render(document.getElementById('search').value);
        })
        .catch(function (error) {
          console.error('EC2 inventory loading failed:', error);
          rows.innerHTML = '<tr><td colspan="6"><div class="state-message"><strong>Could not load instances</strong>' + (error.message || 'Check EC2 permissions and API connectivity.') + '</div></td></tr>';
          toast('Could not load instances', true);
        })
        .finally(function () { document.getElementById('refreshButton').disabled = false; });
    }

    function openIgnoreDialog(instance) {
      selectedIgnoreInstance = instance;
      document.getElementById('ignoreInstance').textContent = (instance.name || instance.instance_id) + ' will remain running until this local time.';
      const parts = (instance.ignore_scheduler || '').split(' ');
      document.getElementById('ignoreTime').value = parts[0] && parts[0].includes(':') ? parts[0] : '';
      document.getElementById('ignoreTimezone').value = parts.slice(1).join(' ') || 'Europe/Amsterdam';
      document.getElementById('removeIgnore').style.visibility = instance.ignore_scheduler ? 'visible' : 'hidden';
      document.getElementById('ignoreDialog').showModal();
    }

    function updateIgnore(ignoreUntil, timezone) {
      if (!selectedIgnoreInstance) return;
      const save = document.getElementById('saveIgnore');
      save.disabled = true;
      request('/instances/ignore', {
        method:'POST',
        headers:{'Content-Type':'text/plain;charset=UTF-8'},
        body:JSON.stringify({instance_id:selectedIgnoreInstance.instance_id, ignore_until:ignoreUntil, timezone:timezone})
      })
        .then(function (data) {
          selectedIgnoreInstance.ignore_scheduler = data.ignore_scheduler || '';
          document.getElementById('ignoreDialog').close();
          toast(data.ignore_scheduler ? 'Scheduler override assigned' : 'Scheduler override removed');
          render(document.getElementById('search').value);
        })
        .catch(function (error) {
          console.error('Ignore scheduler update failed:', error);
          toast(error.message || 'Could not update override', true);
        })
        .finally(function () { save.disabled = false; });
    }

    document.getElementById('search').addEventListener('input', function (event) { render(event.target.value); });
    document.getElementById('closeCalendar').addEventListener('click', function () { calendarDialog.close(); });
    document.getElementById('refreshButton').addEventListener('click', load);
    document.getElementById('cancelIgnore').addEventListener('click', function () { document.getElementById('ignoreDialog').close(); });
    document.getElementById('removeIgnore').addEventListener('click', function () {
      if (window.confirm('Remove the Ignore_scheduler override from this instance?')) updateIgnore('', '');
    });
    document.getElementById('ignoreForm').addEventListener('submit', function (event) {
      event.preventDefault();
      updateIgnore(document.getElementById('ignoreTime').value, document.getElementById('ignoreTimezone').value);
    });
    load();
  </script>
</body>
</html>
