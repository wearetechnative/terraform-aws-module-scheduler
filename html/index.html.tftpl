<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#112f41">
  <link rel="icon" href="favicon.svg" type="image/svg+xml">
  <title>Instance Scheduler</title>
  <script src="auth.js"></script>
  <style>
    :root {
      --ink: #112f41;
      --muted: #607582;
      --line: #dce7eb;
      --paper: #f3f7f8;
      --card: #ffffff;
      --accent: #72c8d3;
      --accent-dark: #3995a4;
      --dark: #112f41;
      --shadow: 0 18px 50px rgba(17, 47, 65, .09);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--ink);
      background: var(--paper);
      font: 15px/1.5 Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    a { color: inherit; text-decoration: none; }
    button { font: inherit; }
    .shell { min-height: 100vh; display: grid; grid-template-columns: 248px 1fr; }
    .sidebar {
      position: sticky; top: 0; height: 100vh; padding: 28px 20px;
      background: var(--dark); color: #fff; display: flex; flex-direction: column;
    }
    .brand { display: block; margin-bottom: 28px; padding: 10px 12px; border-radius: 12px; background: #fff; }
    .brand-logo { display: block; width: 100%; height: auto; }
    .nav-label { margin: 0 10px 9px; color: #89938e; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .11em; }
    .nav { display: grid; gap: 6px; }
    .nav a { display: flex; gap: 12px; align-items: center; padding: 11px 12px; border-radius: 10px; color: #aeb8b2; font-weight: 600; }
    .nav a:hover, .nav a.active { color: #fff; background: #1b4359; }
    .nav a.active::before { content: ""; width: 4px; height: 18px; border-radius: 9px; background: var(--accent); margin-left: -12px; }
    .nav svg { width: 18px; height: 18px; }
    .sidebar-foot { margin-top: auto; padding: 16px; border: 1px solid #31566a; border-radius: 14px; color: #a9bbc5; font-size: 12px; }
    .sidebar-foot strong { display: block; color: #fff; font-size: 13px; margin-bottom: 4px; }
    main { padding: 36px 44px 60px; min-width: 0; }
    .topbar { display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 34px; }
    .eyebrow { margin: 0 0 5px; color: var(--muted); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; }
    h1 { margin: 0; font-size: clamp(28px, 3vw, 42px); line-height: 1.08; letter-spacing: -.045em; }
    .status { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #fff; border: 1px solid var(--line); border-radius: 999px; color: var(--muted); font-size: 12px; font-weight: 650; }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #55b685; box-shadow: 0 0 0 4px #e6f5ed; }
    .hero {
      position: relative; overflow: hidden; padding: 36px; border-radius: 24px;
      color: #fff; background: var(--dark); box-shadow: var(--shadow);
    }
    .hero::after { content: ""; position: absolute; width: 310px; height: 310px; right: -100px; top: -140px; border: 55px solid rgba(114,200,211,.14); border-radius: 50%; }
    .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.5fr .8fr; gap: 40px; align-items: end; }
    .hero h2 { max-width: 650px; margin: 0 0 14px; font-size: clamp(27px, 3.2vw, 48px); line-height: 1.05; letter-spacing: -.05em; }
    .hero h2 em { color: var(--accent); font-style: normal; }
    .hero p { max-width: 570px; margin: 0; color: #b8cad3; font-size: 16px; }
    .hero-actions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10px; }
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 9px; min-height: 43px; padding: 0 17px; border: 0; border-radius: 10px; cursor: pointer; font-weight: 700; }
    .btn-primary { background: var(--accent); color: var(--dark); }
    .btn-secondary { background: #21485d; color: #fff; }
    .btn svg { width: 16px; }
    .metrics { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 22px 0; }
    .metric { padding: 22px; background: var(--card); border: 1px solid var(--line); border-radius: 16px; }
    .metric-head { display: flex; justify-content: space-between; align-items: center; color: var(--muted); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; }
    .metric-icon { width: 31px; height: 31px; display: grid; place-items: center; border-radius: 9px; background: #f0f3ec; color: var(--ink); }
    .metric-value { margin-top: 16px; font-size: 30px; font-weight: 760; letter-spacing: -.04em; }
    .metric-note { margin-top: 2px; color: var(--muted); font-size: 12px; }
    .section-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 22px; }
    .panel { background: var(--card); border: 1px solid var(--line); border-radius: 18px; overflow: hidden; }
    .panel-head { display: flex; justify-content: space-between; align-items: center; padding: 21px 22px; border-bottom: 1px solid var(--line); }
    .panel-head h3 { margin: 0; font-size: 16px; letter-spacing: -.02em; }
    .text-link { color: #65715f; font-size: 12px; font-weight: 700; }
    .schedule-list { padding: 4px 22px; }
    .schedule-row { display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 17px 0; border-bottom: 1px solid var(--line); }
    .schedule-row:last-child { border-bottom: 0; }
    .schedule-name { display: flex; align-items: center; gap: 12px; min-width: 0; font-weight: 700; }
    .schedule-icon { flex: 0 0 auto; width: 36px; height: 36px; display: grid; place-items: center; border-radius: 10px; background: #f1f4ed; }
    .schedule-meta { color: var(--muted); font-size: 12px; font-weight: 500; }
    .pill { padding: 5px 9px; border-radius: 999px; background: #eaf7ef; color: #25704b; font-size: 11px; font-weight: 750; }
    .steps { padding: 8px 22px 18px; }
    .step { display: grid; grid-template-columns: 30px 1fr; gap: 13px; padding: 14px 0; }
    .step-num { width: 28px; height: 28px; display: grid; place-items: center; border-radius: 8px; color: var(--dark); background: var(--accent); font-size: 12px; font-weight: 800; }
    .step strong { display: block; margin-bottom: 3px; font-size: 13px; }
    .step p { margin: 0; color: var(--muted); font-size: 12px; }
    .empty { padding: 28px 0; text-align: center; color: var(--muted); }
    .skeleton { height: 54px; margin: 10px 0; border-radius: 10px; background: linear-gradient(90deg,#f1f3f0 25%,#fafbfa 37%,#f1f3f0 63%); background-size: 400% 100%; animation: shimmer 1.4s infinite; }
    @keyframes shimmer { from { background-position: 100% 0; } to { background-position: 0 0; } }
    @media (max-width: 900px) {
      .shell { grid-template-columns: 1fr; }
      .sidebar { position: static; height: auto; padding: 18px 20px; }
      .brand { padding-bottom: 15px; }
      .nav-label, .sidebar-foot { display: none; }
      .nav { display: flex; overflow-x: auto; }
      .nav a { white-space: nowrap; }
      main { padding: 28px 20px 50px; }
      .hero-grid, .section-grid { grid-template-columns: 1fr; }
      .hero-actions { justify-content: flex-start; }
    }
    @media (max-width: 600px) {
      .topbar { align-items: flex-start; }
      .status { display: none; }
      .hero { padding: 27px 23px; }
      .metrics { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <a class="brand" href="index.html"><img class="brand-logo" src="technativelogo.svg" alt="TechNative"></a>
      <p class="nav-label">Workspace</p>
      <nav class="nav">
        <a class="active" href="index.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="2"/><rect x="14" y="3" width="7" height="7" rx="2"/><rect x="3" y="14" width="7" height="7" rx="2"/><rect x="14" y="14" width="7" height="7" rx="2"/></svg> Overview</a>
        <a href="schedules.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 10h18"/></svg> Schedules</a>
        <a href="periods.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg> Periods</a>
        <a href="instances.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="7" rx="2"/><rect x="3" y="13" width="18" height="7" rx="2"/><path d="M7 7.5h.01M7 16.5h.01"/></svg> Instances</a>
      </nav>
      <div class="sidebar-foot"><strong>AWS connected</strong>Schedules are evaluated automatically by EventBridge.</div>
    </aside>

    <main>
      <header class="topbar">
        <div><p class="eyebrow">Operations console</p><h1>Good to see you.</h1></div>
        <div class="status"><span class="status-dot"></span> Scheduler online</div>
      </header>

      <section class="hero">
        <div class="hero-grid">
          <div>
            <h2>Run infrastructure only when it <em>needs to run.</em></h2>
            <p>Build reusable operating windows, assign them to schedules, and run your AWS instances only when needed, reducing unnecessary cloud spend.</p>
          </div>
          <div class="hero-actions">
            <a class="btn btn-secondary" href="schedules.html">View schedules</a>
            <a class="btn btn-primary" href="instances.html">Manage instances <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></a>
          </div>
        </div>
      </section>

      <section class="metrics" aria-label="Scheduler summary">
        <article class="metric">
          <div class="metric-head"><span>Schedules</span><span class="metric-icon">#</span></div>
          <div class="metric-value" id="scheduleCount">—</div>
          <div class="metric-note">Configured automation rules</div>
        </article>
        <article class="metric">
          <div class="metric-head"><span>Service status</span><span class="metric-icon">✓</span></div>
          <div class="metric-value" style="font-size:24px">Operational</div>
          <div class="metric-note">API is responding normally</div>
        </article>
      </section>

      <section class="section-grid">
        <article class="panel">
          <div class="panel-head"><h3>Configured schedules</h3><a class="text-link" href="schedules.html">View all →</a></div>
          <div class="schedule-list" id="scheduleList">
            <div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div>
          </div>
        </article>
        <article class="panel">
          <div class="panel-head"><h3>How instance scheduling works</h3></div>
          <div class="steps">
            <div class="step"><span class="step-num">1</span><div><strong>Create reusable periods</strong><p>Define the weekdays, start and stop times, and timezone for each operating window.</p></div></div>
            <div class="step"><span class="step-num">2</span><div><strong>Build a schedule</strong><p>Combine one or more periods into a named schedule, such as office hours or weekend coverage.</p></div></div>
            <div class="step"><span class="step-num">3</span><div><strong>Assign it to EC2</strong><p>Choose a schedule on the Instances page. The app manages the InstanceScheduler tag for you.</p></div></div>
            <div class="step"><span class="step-num">4</span><div><strong>Temporarily ignore stopping</strong><p>Set Ignore_scheduler with an end time and timezone to keep an instance running. Its regular schedule remains assigned and resumes after the override expires.</p></div></div>
          </div>
        </article>
      </section>
    </main>
  </div>
  <script>
    const apiUrl = '${api_url}';
    const list = document.getElementById('scheduleList');
    fetch(apiUrl + '/db')
      .then(function (response) {
        if (!response.ok) throw new Error('API unavailable');
        return response.json();
      })
      .then(function (data) {
        const schedules = data.schedules_list || [];
        document.getElementById('scheduleCount').textContent = schedules.length;
        if (!schedules.length) {
          list.innerHTML = '<div class="empty">No schedules configured yet.</div>';
          return;
        }
        list.innerHTML = '';
        schedules.slice(0, 4).forEach(function (name) {
          const row = document.createElement('a');
          row.className = 'schedule-row';
          row.href = 'periods.html?schedule=' + encodeURIComponent(name);
          const left = document.createElement('div');
          left.className = 'schedule-name';
          left.innerHTML = '<span class="schedule-icon">↗</span><span></span>';
          left.querySelector('span:last-child').textContent = name;
          const pill = document.createElement('span');
          pill.className = 'pill';
          pill.textContent = 'Active';
          row.appendChild(left);
          row.appendChild(pill);
          list.appendChild(row);
        });
      })
      .catch(function (error) {
        console.error('Scheduler API request failed:', error);
        document.getElementById('scheduleCount').textContent = '—';
        list.innerHTML = '<div class="empty">Could not reach the scheduler API. Check the browser console for the HTTP or CORS error.</div>';
      });
  </script>
</body>
</html>
