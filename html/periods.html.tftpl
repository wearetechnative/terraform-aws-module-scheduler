<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#17201c">
  <title>Periods · Instance Scheduler</title>
  <style>
    :root { --ink:#17201c; --muted:#69736d; --line:#e2e6e3; --paper:#f5f6f2; --accent:#d8ff5f; --dark:#17201c; --danger:#a93838; }
    * { box-sizing:border-box; }
    body { margin:0; color:var(--ink); background:var(--paper); font:15px/1.5 Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; }
    a { color:inherit; text-decoration:none; }
    button,input,select { font:inherit; }
    .shell { min-height:100vh; display:grid; grid-template-columns:248px 1fr; }
    .sidebar { position:sticky; top:0; height:100vh; padding:28px 20px; background:var(--dark); color:#fff; display:flex; flex-direction:column; }
    .brand { display:flex; align-items:center; gap:11px; font-weight:750; letter-spacing:-.02em; padding:0 8px 34px; }
    .brand-mark { width:34px; height:34px; border-radius:10px; display:grid; place-items:center; background:var(--accent); color:var(--dark); }
    .nav-label { margin:0 10px 9px; color:#89938e; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.11em; }
    .nav { display:grid; gap:6px; }
    .nav a { display:flex; gap:12px; align-items:center; padding:11px 12px; border-radius:10px; color:#aeb8b2; font-weight:600; }
    .nav a:hover,.nav a.active { color:#fff; background:#26312c; }
    .nav a.active::before { content:""; width:4px; height:18px; border-radius:9px; background:var(--accent); margin-left:-12px; }
    .nav svg { width:18px; height:18px; }
    .sidebar-foot { margin-top:auto; padding:16px; border:1px solid #35413b; border-radius:14px; color:#9da8a2; font-size:12px; }
    .sidebar-foot strong { display:block; color:#fff; font-size:13px; margin-bottom:4px; }
    main { padding:36px 44px 60px; min-width:0; }
    .topbar { display:flex; justify-content:space-between; align-items:flex-end; gap:20px; margin-bottom:28px; }
    .eyebrow { margin:0 0 5px; color:var(--muted); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.12em; }
    h1 { margin:0; font-size:clamp(30px,3vw,42px); line-height:1.08; letter-spacing:-.045em; }
    .subtitle { margin:8px 0 0; color:var(--muted); }
    .selector-card { display:flex; justify-content:space-between; align-items:center; gap:22px; padding:20px 22px; margin-bottom:20px; border:1px solid var(--line); border-radius:16px; background:#fff; }
    .selector-card label { display:block; margin-bottom:4px; font-size:12px; font-weight:750; }
    .selector-card p { margin:0; color:var(--muted); font-size:12px; }
    select,input { height:42px; padding:0 12px; border:1px solid #d6dbd7; border-radius:9px; background:#fff; color:var(--ink); outline:none; }
    select:focus,input:focus { border-color:#9aa68f; box-shadow:0 0 0 3px #edf2e4; }
    #scheduleDropdown { min-width:260px; }
    .panel { background:#fff; border:1px solid var(--line); border-radius:18px; overflow:hidden; }
    .panel-head { display:flex; justify-content:space-between; align-items:center; gap:16px; padding:18px 20px; border-bottom:1px solid var(--line); }
    .panel-head h2 { margin:0; font-size:16px; letter-spacing:-.02em; }
    .panel-head span { color:var(--muted); font-size:12px; }
    .btn { min-height:40px; padding:0 15px; display:inline-flex; align-items:center; justify-content:center; gap:8px; border:0; border-radius:9px; background:var(--dark); color:#fff; cursor:pointer; font-weight:700; }
    .btn:disabled { cursor:not-allowed; opacity:.45; }
    .btn.accent { background:var(--accent); color:var(--dark); }
    .btn.ghost { color:var(--muted); background:#f2f4f0; }
    .btn.danger { color:var(--danger); background:#fff0f0; }
    table { width:100%; border-collapse:collapse; }
    th { padding:13px 18px; color:var(--muted); background:#fafbf9; border-bottom:1px solid var(--line); text-align:left; font-size:11px; text-transform:uppercase; letter-spacing:.08em; }
    td { padding:16px 18px; border-bottom:1px solid var(--line); vertical-align:middle; }
    tbody tr:last-child td { border-bottom:0; }
    .period-name { font-weight:730; }
    .days { display:flex; gap:4px; flex-wrap:wrap; }
    .day { width:28px; height:27px; display:grid; place-items:center; border-radius:7px; color:#536058; background:#eef1ec; font-size:10px; font-weight:750; text-transform:uppercase; }
    .time { font-variant-numeric:tabular-nums; font-weight:650; }
    .timezone { color:var(--muted); font-size:12px; }
    .state { padding:66px 20px; text-align:center; color:var(--muted); }
    .state-icon { width:45px; height:45px; margin:0 auto 12px; display:grid; place-items:center; border-radius:13px; background:#f0f3ed; color:var(--ink); font-size:19px; }
    .state strong { display:block; color:var(--ink); margin-bottom:4px; }
    .form-row { background:#fbfcfa; }
    .form-row td { vertical-align:top; }
    .field-label { display:block; margin-bottom:6px; color:var(--muted); font-size:10px; font-weight:750; text-transform:uppercase; letter-spacing:.06em; }
    .form-row input,.form-row select { width:100%; min-width:110px; }
    .day-picker { display:grid; grid-template-columns:repeat(4,1fr); gap:5px; min-width:180px; }
    .day-picker label { cursor:pointer; }
    .day-picker input { position:absolute; opacity:0; pointer-events:none; }
    .day-picker span { height:28px; display:grid; place-items:center; border:1px solid var(--line); border-radius:7px; background:#fff; font-size:10px; font-weight:750; text-transform:uppercase; }
    .day-picker input:checked + span { border-color:var(--dark); background:var(--dark); color:#fff; }
    .form-actions { display:flex; gap:7px; }
    .toast { position:fixed; right:24px; bottom:24px; max-width:360px; padding:13px 16px; border-radius:11px; background:var(--dark); color:#fff; box-shadow:0 15px 40px rgba(0,0,0,.18); transform:translateY(20px); opacity:0; pointer-events:none; transition:.2s ease; font-size:13px; font-weight:650; }
    .toast.show { transform:translateY(0); opacity:1; }
    .toast.error { background:#8d3030; }
    @media (max-width:1000px) { .table-wrap{overflow-x:auto}table{min-width:900px} }
    @media (max-width:900px) { .shell{grid-template-columns:1fr}.sidebar{position:static;height:auto;padding:18px 20px}.brand{padding-bottom:15px}.nav-label,.sidebar-foot{display:none}.nav{display:flex;overflow-x:auto}.nav a{white-space:nowrap}main{padding:28px 20px 50px} }
    @media (max-width:620px) { .topbar{align-items:flex-start;flex-direction:column}.selector-card{align-items:flex-start;flex-direction:column}#scheduleDropdown{width:100%;min-width:0}.selector-card>div:last-child{width:100%} }
  </style>
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <a class="brand" href="index.html"><span class="brand-mark"><svg viewBox="0 0 24 24" width="19" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 3v9l5 3"/><circle cx="12" cy="12" r="9"/></svg></span>Instance Scheduler</a>
      <p class="nav-label">Workspace</p>
      <nav class="nav">
        <a href="index.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="2"/><rect x="14" y="3" width="7" height="7" rx="2"/><rect x="3" y="14" width="7" height="7" rx="2"/><rect x="14" y="14" width="7" height="7" rx="2"/></svg> Overview</a>
        <a href="schedules.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 10h18"/></svg> Schedules</a>
        <a class="active" href="periods.html"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg> Periods</a>
      </nav>
      <div class="sidebar-foot"><strong>Safety rule</strong>Every schedule must retain at least one period.</div>
    </aside>
    <main>
      <header class="topbar">
        <div><p class="eyebrow">Time windows</p><h1>Periods</h1><p class="subtitle">Set the exact days and hours when a schedule should keep instances running.</p></div>
        <button class="btn accent" id="addButton" disabled>+ Add period</button>
      </header>
      <section class="selector-card">
        <div><label for="scheduleDropdown">Schedule</label><p>Select a schedule to inspect and edit its operating periods.</p></div>
        <div><select id="scheduleDropdown" disabled><option value="">Loading schedules…</option></select></div>
      </section>
      <section class="panel">
        <div class="panel-head"><div><h2 id="panelTitle">Schedule periods</h2><span id="periodCount">Select a schedule to continue</span></div></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Period name</th><th>Days</th><th>Start</th><th>Stop</th><th>Timezone</th><th>Action</th></tr></thead>
            <tbody id="periodRows"><tr><td colspan="6"><div class="state"><div class="state-icon">◷</div><strong>No schedule selected</strong>Choose a schedule above to view its periods.</div></td></tr></tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
  <div class="toast" id="toast" role="status"></div>
  <script>
    const apiUrl = '${api_url}';
    const configuredSchedules = ${schedule_names};
    const dropdown = document.getElementById('scheduleDropdown');
    const rows = document.getElementById('periodRows');
    const addButton = document.getElementById('addButton');
    let periods = [];
    let adding = false;

    function toast(message, isError) {
      const el = document.getElementById('toast');
      el.textContent = message;
      el.className = 'toast show' + (isError ? ' error' : '');
      window.setTimeout(function () { el.className = 'toast'; }, 2800);
    }

    function request(path, options) {
      return fetch(apiUrl + path, options).then(function (response) {
        return response.text().then(function (text) {
          if (!response.ok) throw new Error(text || 'Request failed');
          if (!text) return {};

          let data;
          try {
            data = JSON.parse(text);
          } catch (error) {
            return text;
          }

          // Also support invoking the Lambda response shape directly.
          if (data && typeof data.body === 'string') {
            try {
              return JSON.parse(data.body);
            } catch (error) {
              return data.body;
            }
          }
          return data;
        });
      });
    }

    function render() {
      rows.innerHTML = '';
      document.getElementById('periodCount').textContent = periods.length + (periods.length === 1 ? ' period assigned' : ' periods assigned');
      if (!periods.length && !adding) {
        rows.innerHTML = '<tr><td colspan="6"><div class="state"><div class="state-icon">◷</div><strong>No periods returned</strong>This schedule does not have any readable periods.</div></td></tr>';
        return;
      }
      periods.forEach(function (period) {
        const periodName = attributeValue(period.name, '');
        const periodDays = attributeValue(period.days, []);
        const beginTime = attributeValue(period.begintime, '');
        const endTime = attributeValue(period.endtime, '');
        const periodTimezone = attributeValue(period.timezone, '');
        const row = document.createElement('tr');
        const name = document.createElement('td'); name.className = 'period-name'; name.textContent = periodName;
        const daysCell = document.createElement('td'); const days = document.createElement('div'); days.className = 'days';
        periodDays.forEach(function (day) { const item = document.createElement('span'); item.className = 'day'; item.textContent = day; days.appendChild(item); });
        daysCell.appendChild(days);
        const start = document.createElement('td'); start.className = 'time'; start.textContent = beginTime;
        const end = document.createElement('td'); end.className = 'time'; end.textContent = endTime;
        const zone = document.createElement('td'); zone.className = 'timezone'; zone.textContent = periodTimezone;
        const action = document.createElement('td'); const button = document.createElement('button'); button.className = 'btn danger'; button.textContent = 'Remove';
        button.addEventListener('click', function () { removePeriod(periodName); }); action.appendChild(button);
        row.appendChild(name); row.appendChild(daysCell); row.appendChild(start); row.appendChild(end); row.appendChild(zone); row.appendChild(action);
        rows.appendChild(row);
      });
      if (adding) renderForm();
    }

    function attributeValue(attribute, fallback) {
      if (attribute === undefined || attribute === null) return fallback;
      if (typeof attribute !== 'object' || Array.isArray(attribute)) return attribute;
      if (Object.prototype.hasOwnProperty.call(attribute, 'S')) return attribute.S;
      if (Object.prototype.hasOwnProperty.call(attribute, 'SS')) return attribute.SS;
      return fallback;
    }

    function renderForm() {
      const row = document.createElement('tr');
      row.className = 'form-row';
      row.innerHTML =
        '<td><label class="field-label" for="periodName">Name</label><input id="periodName" placeholder="office-hours"></td>' +
        '<td><span class="field-label">Weekdays</span><div class="day-picker">' +
        ['mon','tue','wed','thu','fri','sat','sun'].map(function (day) { return '<label><input type="checkbox" name="day" value="' + day + '"><span>' + day + '</span></label>'; }).join('') +
        '</div></td>' +
        '<td><label class="field-label" for="beginTime">Start time</label><input id="beginTime" type="time" value="09:00"></td>' +
        '<td><label class="field-label" for="endTime">Stop time</label><input id="endTime" type="time" value="17:00"></td>' +
        '<td><label class="field-label" for="timezone">Timezone</label><select id="timezone"><option>Europe/Amsterdam</option><option>Europe/London</option><option>UTC</option><option>America/New_York</option><option>America/Los_Angeles</option><option>Asia/Kolkata</option><option>Asia/Singapore</option><option>Australia/Sydney</option></select></td>' +
        '<td><span class="field-label">Action</span><div class="form-actions"><button class="btn accent" id="savePeriod">Save</button><button class="btn ghost" id="cancelPeriod">Cancel</button></div></td>';
      rows.appendChild(row);
      document.getElementById('savePeriod').addEventListener('click', savePeriod);
      document.getElementById('cancelPeriod').addEventListener('click', function () { adding = false; addButton.disabled = false; render(); });
      document.getElementById('periodName').focus();
    }

    function loadPeriods() {
      const schedule = dropdown.value;
      addButton.disabled = !schedule;
      adding = false;
      if (!schedule) {
        periods = [];
        document.getElementById('panelTitle').textContent = 'Schedule periods';
        document.getElementById('periodCount').textContent = 'Select a schedule to continue';
        rows.innerHTML = '<tr><td colspan="6"><div class="state"><div class="state-icon">◷</div><strong>No schedule selected</strong>Choose a schedule above to view its periods.</div></td></tr>';
        return;
      }
      document.getElementById('panelTitle').textContent = schedule;
      rows.innerHTML = '<tr><td colspan="6"><div class="state">Loading periods…</div></td></tr>';
      request('/db/list_periods', {method:'POST', headers:{'Content-Type':'application/json'}, body:schedule})
        .then(function (data) { periods = data.period_list || []; render(); })
        .catch(function () { rows.innerHTML = '<tr><td colspan="6"><div class="state"><strong>Could not load periods</strong>Check the API and try again.</div></td></tr>'; toast('Could not load periods', true); });
    }

    function savePeriod() {
      const name = document.getElementById('periodName').value.trim();
      const selectedDays = Array.from(document.querySelectorAll('input[name="day"]:checked')).map(function (item) { return item.value; });
      const begin = document.getElementById('beginTime').value;
      const end = document.getElementById('endTime').value;
      if (!name || !selectedDays.length || !begin || !end) { toast('Enter a name, times, and at least one weekday.', true); return; }
      if (periods.some(function (item) { return attributeValue(item.name, '') === name; })) { toast('This schedule already contains that period.', true); return; }
      const payload = {period_name:name, selected_days:selectedDays, begin_time:begin, end_time:end, timezone:document.getElementById('timezone').value, schedule_name:dropdown.value};
      document.getElementById('savePeriod').disabled = true;
      request('/db/add_period', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)})
        .then(function () { adding = false; toast('Period added to ' + dropdown.value); loadPeriods(); })
        .catch(function () { toast('Could not add the period', true); document.getElementById('savePeriod').disabled = false; });
    }

    function removePeriod(name) {
      if (periods.length <= 1) { toast('A schedule must keep at least one period.', true); return; }
      if (!window.confirm('Remove “' + name + '” from ' + dropdown.value + '?')) return;
      const payload = {period_name:name, selected_schedule:dropdown.value};
      request('/db/delete_period', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)})
        .then(function () { toast('Period removed'); loadPeriods(); })
        .catch(function () { toast('Could not remove the period', true); });
    }

    function populateSchedules(schedules) {
        dropdown.innerHTML = '<option value="">Choose a schedule…</option>';
        schedules.forEach(function (name) {
          const option = document.createElement('option');
          option.value = name;
          option.textContent = name;
          dropdown.appendChild(option);
        });
        dropdown.disabled = schedules.length === 0;
        if (!schedules.length) {
          dropdown.innerHTML = '<option value="">No schedules available</option>';
          throw new Error('No schedules are configured');
        }
        const requested = new URLSearchParams(window.location.search).get('schedule');
        if (requested && Array.from(dropdown.options).some(function (option) { return option.value === requested; })) { dropdown.value = requested; loadPeriods(); }
    }

    request('/db')
      .then(function (data) {
        const apiSchedules = data && Array.isArray(data.schedules_list) ? data.schedules_list : [];
        populateSchedules(apiSchedules.length ? apiSchedules : configuredSchedules);
      })
      .catch(function (error) {
        console.error('Schedule API loading failed:', error);
        if (configuredSchedules.length) {
          populateSchedules(configuredSchedules);
          toast('Using schedules from the Terraform configuration', false);
          return;
        }
        dropdown.disabled = true;
        dropdown.innerHTML = '<option value="">Could not load schedules</option>';
        toast('Could not load schedules', true);
      });

    dropdown.addEventListener('change', loadPeriods);
    addButton.addEventListener('click', function () { if (!dropdown.value || adding) return; adding = true; addButton.disabled = true; render(); });
  </script>
</body>
</html>
